PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/bmsce_events
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Gmail (optional). If set: sign-up sends OTP to verify email; forgot-password works.
# If not set: sign-up works without OTP; users can use the site immediately.
# Use App Password if 2FA is enabled: https://myaccount.google.com/apppasswords
# EMAIL_USER=your.gmail@gmail.com
# EMAIL_PASS=your_app_password
